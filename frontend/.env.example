# ──────────────────────────────────────────────
#  LIVEDET Frontend — Environment Variables
# ──────────────────────────────────────────────
#  Copy this file to .env and adjust as needed.
#  VITE_ prefix is required to expose vars to the browser.
# ──────────────────────────────────────────────

# REST API base URL (Flask backend)
VITE_API_URL=http://localhost:8000

# WebSocket server URL (live_ws.py)
VITE_WS_URL=ws://localhost:8765
